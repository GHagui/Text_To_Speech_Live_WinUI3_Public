<Page
    x:Class="TTS_Live_UI.Views.IntroduçãoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" HorizontalAlignment="Center" MaxWidth="800">
        <FlipView Background="Transparent">
            <!-- Slide 1: Welcome -->
            <StackPanel VerticalAlignment="Center" Padding="20">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    Margin="10"
                    TextAlignment="Center">Bem-vindo ao Text To Speech Live UI!</TextBlock>
                <Image Source="\Assets\StoreLogo.scale-400.png"
                       Width="200"
                       Margin="30"/>
                <TextBlock
                    TextWrapping="Wrap"
                    Margin="20"
                    TextAlignment="Center"
                    LineHeight="24">Text To Speech Live UI é um aplicativo construído com .NET 10 e WinUI 3 para converter texto em voz. Digite ou cole um texto, ajuste o volume, a velocidade e escolha entre as vozes instaladas no sistema. Ideal para comunicação, aprendizado e acessibilidade.</TextBlock>
            </StackPanel>

            <!-- Slide 2: How to use with microphone -->
            <StackPanel VerticalAlignment="Center" Padding="20">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    Margin="10"
                    TextAlignment="Center">Como usar com microfone</TextBlock>
                <Image Source="{ThemeResource MyImage}"
                       Width="300"
                       Margin="30"/>
                <TextBlock
                    TextWrapping="Wrap"
                    Margin="20"
                    TextAlignment="Center"
                    LineHeight="24">Use o aplicativo para falar no microfone em reuniões online — útil para pessoas com deficiências auditivas. Conecte um cabo P2 entre a entrada de microfone e a saída de áudio, ou use um driver virtual como o VB-Cable para redirecionar o som. Depois, digite e clique em converter ou ative o recurso Live.</TextBlock>
            </StackPanel>

            <!-- Slide 3: Features overview -->
            <StackPanel VerticalAlignment="Center" Padding="20">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap"
                    Margin="10"
                    TextAlignment="Center">Recursos disponíveis</TextBlock>
                <StackPanel Margin="20" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="57666"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Conversão de texto em voz com controle de volume e velocidade</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="57828"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Modo Live: fala automaticamente ao terminar frases com . ? ou !</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="57604"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Atalhos de texto: frases prontas para falar com um clique</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="57621"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Seleção de voz, ajuste de velocidade e volume integrados</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Salvar áudio como arquivo WAV</TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE790;"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">Temas claro, escuro e padrão do sistema</TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </FlipView>
    </Grid>
</Page>
