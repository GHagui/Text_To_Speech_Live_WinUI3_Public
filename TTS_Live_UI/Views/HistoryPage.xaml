<Page
    x:Class="TTS_Live_UI.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TTS_Live_UI.Core.Models"
    mc:Ignorable="d"
    Loaded="OnPageLoaded">

    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with clear button -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Histórico de Conversões"/>
                <TextBlock
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Todas as conversões de texto para voz são registradas aqui."/>
            </StackPanel>

            <Button
                Grid.Column="1"
                Content="Limpar tudo"
                Command="{x:Bind ViewModel.ClearAllCommand}"
                VerticalAlignment="Center"/>
        </Grid>

        <!-- Empty state -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <FontIcon Glyph="&#xE81C;" FontSize="48" Margin="0,0,0,12"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock
                Text="Nenhuma conversão registrada ainda."
                Style="{ThemeResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- History List -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Items}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConversionHistoryItem">
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Timestamp -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="120">
                            <TextBlock
                                Text="{x:Bind TimestampFormatted}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE767;" FontSize="10"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock
                                    Text="{x:Bind VoiceName}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Text Preview -->
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind TextPreview}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"/>

                        <!-- Replay Button -->
                        <Button Grid.Column="2" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Reproduzir novamente"
                                Click="ReplayItem_Click" Tag="{x:Bind}">
                            <SymbolIcon Symbol="57666"/>
                        </Button>

                        <!-- Remove Button -->
                        <Button Grid.Column="3" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Remover do histórico"
                                Click="RemoveItem_Click" Tag="{x:Bind}">
                            <SymbolIcon Symbol="57610"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
