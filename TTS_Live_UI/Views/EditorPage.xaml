<Page
    x:Class="TTS_Live_UI.Views.EditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TTS_Live_UI.ViewModels"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Description -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Atalhos de Texto"
                Margin="0,0,0,4"/>
            <TextBlock
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Crie frases prontas para falar rapidamente com um clique. Útil para frases frequentes em reuniões e conversas."/>
        </StackPanel>

        <!-- Row 1: Add New Shortcut -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Header="Rótulo"
                PlaceholderText="Ex: Saudação"
                Text="{x:Bind ViewModel.NewLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Width="150"
                Margin="0,0,8,0"/>

            <TextBox
                Grid.Column="1"
                Header="Texto para falar"
                PlaceholderText="Ex: Olá, tudo bem?"
                Text="{x:Bind ViewModel.NewText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                Margin="0,0,8,0"/>

            <Button
                Grid.Column="2"
                Content="Adicionar"
                Command="{x:Bind ViewModel.AddShortcutCommand}"
                VerticalAlignment="Bottom"
                Height="40"
                Style="{ThemeResource AccentButtonStyle}"/>
        </Grid>

        <!-- Row 2: Shortcuts List -->
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Shortcuts}"
            SelectedItem="{x:Bind ViewModel.SelectedShortcut, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TextShortcut">
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Label -->
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind Label, Mode=OneWay}"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            VerticalAlignment="Center"/>

                        <!-- Text Preview -->
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind Text, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <!-- Speak Button -->
                        <Button
                            Grid.Column="2"
                            ToolTipService.ToolTip="Falar este atalho"
                            VerticalAlignment="Center">
                            <SymbolIcon Symbol="57666"/>
                        </Button>

                        <!-- Remove Button -->
                        <Button
                            Grid.Column="3"
                            ToolTipService.ToolTip="Remover atalho"
                            VerticalAlignment="Center">
                            <SymbolIcon Symbol="57610"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
